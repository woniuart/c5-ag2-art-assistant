# ArtGuide AG2 - 艺术鉴赏多智能体教学助手
# 环境变量配置示例
# 复制此文件为 .env 并填写真实值

# ============ LLM API 配置（必需）============
# SiliconFlow API（推荐，有免费额度）
OPENROUTER_API_KEY=sk-your-siliconflow-key-here
OPENROUTER_BASE_URL=https://api.siliconflow.cn/v1

# 默认文本分析模型（SiliconFlow 支持）
AG2_DEFAULT_MODEL=MiniMaxAI/MiniMax-M2.5

# ============ 视觉模型配置 ============
# 方案1：SiliconFlow 视觉模型（推荐，性价比高）
VISION_MODEL=Qwen/Qwen2-VL-7B-Instruct
# 可选：Qwen/Qwen2-VL-72B-Instruct（更大，更准确）

# 方案2：OpenRouter（更多模型选择，需要 OpenRouter API Key）
# OPENROUTER_API_KEY=sk-or-v1-xxx
# VISION_BASE_URL=https://openrouter.ai/api/v1
# VISION_MODEL=google/gemini-2.0-flash-001
# 可选视觉模型：
#   - google/gemini-2.0-flash-001（快速，便宜）
#   - anthropic/claude-3.5-sonnet（最强视觉分析）
#   - openai/gpt-4o（强大）
#   - Qwen/Qwen2-VL-72B-Instruct（开源最强）

# 方案3：同时使用多个视觉模型（在界面中选择）
# 在 .env 中配置，应用启动时加载
VISION_MODEL_OPTIONS=Qwen/Qwen2-VL-7B-Instruct,google/gemini-2.0-flash-001,anthropic/claude-3.5-sonnet

# ============ 分析技能开关 ============
# 是否启用高级分析技能（默认全部启用）
ENABLE_COMPOSITION_ANALYSIS=true      # 构图分析
ENABLE_STYLE_ANALYSIS=true            # 风格分析
ENABLE_HISTORICAL_CONTEXT=true        # 历史背景分析
ENABLE_EMOTION_ANALYSIS=true         # 情感分析
ENABLE_TECHNIQUE_ANALYSIS=true       # 技法分析
ENABLE_COLOR_ANALYSIS=true           # 色彩分析（默认启用）

# ============ 网页搜索（可选）============
TAVILY_API_KEY=your_tavily_key_here

# ============ 飞书智能体（可选）============
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret
