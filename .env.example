# ArtGuide AG2 - 艺术鉴赏多智能体教学助手
# 环境变量配置示例
# 复制此文件为 .env 并填写真实值

# ============ LLM API 配置（必需）============
# SiliconFlow API（推荐，有免费额度）
OPENROUTER_API_KEY=sk-your-siliconflow-key-here
OPENROUTER_BASE_URL=https://api.siliconflow.cn/v1

# ============ 模型配置 ============
# 文本模型（用于文字分析 - 不需要视觉能力）
# 可选：Qwen/Qwen2.5-7B-Instruct, deepseek-ai/DeepSeek-V2.5, MiniMaxAI/MiniMax-M2.5
AG2_DEFAULT_MODEL=Qwen/Qwen2.5-7B-Instruct

# 视觉模型（用于图片分析 - 必须是VLM视觉语言模型）
# SiliconFlow 当前可用视觉模型（2025年6月更新）：
#   - Qwen/Qwen3-VL-8B-Instruct  （推荐，性价比高）
#   - Qwen/Qwen3-VL-32B-Instruct （更大更准确）
#   - Qwen/Qwen3-Omni-30B-A3B-Instruct（多模态全能）
# 注意：旧版 Qwen2-VL 系列已不可用
VISION_MODEL=Qwen/Qwen3-VL-8B-Instruct

# 重要：视觉模型必须是支持图像的VLM！
# 可用模型列表查询：curl -H "Authorization: Bearer $API_KEY" https://api.siliconflow.cn/v1/models

# ============ 分析技能开关 ============
ENABLE_COMPOSITION_ANALYSIS=true      # 构图分析
ENABLE_STYLE_ANALYSIS=true            # 风格分析
ENABLE_HISTORICAL_CONTEXT=true        # 历史背景分析
ENABLE_EMOTION_ANALYSIS=true         # 情感分析
ENABLE_TECHNIQUE_ANALYSIS=true       # 技法分析
ENABLE_COLOR_ANALYSIS=true           # 色彩分析

# ============ 网页搜索（可选）============
TAVILY_API_KEY=

# ============ 飞书智能体（可选）============
FEISHU_APP_ID=
FEISHU_APP_SECRET=
