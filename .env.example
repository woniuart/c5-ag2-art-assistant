# Art Assistant Agent Environment Example
# Copy to .env and fill in your API keys

# --- LLM access via OpenRouter ---
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Default model for Beta agents
# Options: google/gemini-2.5-flash, google/gemini-2.5-pro, anthropic/claude-3.5-sonnet
AG2_DEFAULT_MODEL=google/gemini-2.5-flash

# --- Web search (optional) ---
TAVILY_API_KEY=your_tavily_api_key_here