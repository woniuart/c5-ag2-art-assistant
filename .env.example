# ArtGuide AG2 - 艺术鉴赏多智能体教学助手
# 环境变量配置示例
# 复制此文件为 .env 并填写真实值

# ============ LLM API 配置（必需）============
# SiliconFlow API（推荐，有免费额度）
OPENROUTER_API_KEY=sk-your-siliconflow-key-here
OPENROUTER_BASE_URL=https://api.siliconflow.cn/v1

# 默认文本分析模型（SiliconFlow 支持）
AG2_DEFAULT_MODEL=MiniMaxAI/MiniMax-M2.5

# 视觉识图模型（选一个，取消注释使用）
# 方案1：SiliconFlow 视觉模型（推荐）
VISION_MODEL=Qwen/Qwen2-VL-7B-Instruct
# 方案2：OpenRouter（需要 OpenRouter API Key）
# OPENROUTER_API_KEY=sk-or-v1-xxx
# VISION_BASE_URL=https://openrouter.ai/api/v1
# VISION_MODEL=google/gemini-2.0-flash-001


# ============ 网页搜索（可选）============
TAVILY_API_KEY=your_tavily_key_here


# ============ 飞书智能体（可选）============
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret
