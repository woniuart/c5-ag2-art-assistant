# ArtGuide AG2 - 环境变量配置
# 部署到 Render 时，请在 Dashboard 的 Environment 中设置这些变量

# ============ LLM API 配置（必需）============
OPENROUTER_API_KEY=sk-your-siliconflow-key-here
OPENROUTER_BASE_URL=https://api.siliconflow.cn/v1

# ============ 模型配置 ============
# 文本模型（用于文字分析）
AG2_DEFAULT_MODEL=Qwen/Qwen2.5-7B-Instruct

# 视觉模型（用于图片分析 - 必须是VLM！）
# SiliconFlow 可用视觉模型（2025年6月更新）：
#   - Qwen/Qwen3-VL-8B-Instruct  （推荐，性价比高）
#   - Qwen/Qwen3-VL-32B-Instruct （更大更准确）
#   - Qwen/Qwen3-Omni-30B-A3B-Instruct（多模态全能）
# 注意：旧版 Qwen2-VL 系列已不可用
VISION_MODEL=Qwen/Qwen3-VL-8B-Instruct

# ============ 技能开关 ============
ENABLE_COMPOSITION_ANALYSIS=true
ENABLE_STYLE_ANALYSIS=true
ENABLE_HISTORICAL_CONTEXT=true
ENABLE_EMOTION_ANALYSIS=true
ENABLE_TECHNIQUE_ANALYSIS=true
ENABLE_COLOR_ANALYSIS=true

# ============ 可选配置 ============
TAVILY_API_KEY=
FEISHU_APP_ID=
FEISHU_APP_SECRET=
